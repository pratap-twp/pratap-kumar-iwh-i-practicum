
doctype html
html
  head
    title= title
    meta(name="viewport", content="width=device-width, initial-scale=1")
    link(rel="stylesheet", href="/css/style.css")

  body
    .container
      h1 Custom Object Table

      a.add-link(href="/update-cobj") Add to this table

      table
        thead
          tr
            th Name
            th Author
            th Price
        tbody
          each item in data
            tr
              td= item.properties.name
              td= item.properties.author
              td= item.properties.price